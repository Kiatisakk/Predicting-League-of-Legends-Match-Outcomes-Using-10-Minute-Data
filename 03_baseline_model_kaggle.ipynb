      ],
      "text/plain": [
       "        split   rows  blue_win_ratio\n",
       "0       train  63975        0.500055\n",
       "1  validation  13709        0.500036\n",
       "2        test  13710        0.500073"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
